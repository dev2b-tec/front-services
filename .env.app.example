# =============================================================================
# front-services — variáveis de ambiente
# Copie este arquivo para .env.app e preencha os valores reais.
# O arquivo .env.app NÃO deve ser commitado (já está no .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# NextAuth / Auth.js
# -----------------------------------------------------------------------------
# URL pública da aplicação (sem barra final)
AUTH_URL=https://app.dev2b.tec.br

# Segredo para assinar os tokens de sessão — gere com: openssl rand -hex 32
AUTH_SECRET=TROQUE_POR_UM_SEGREDO_FORTE

# -----------------------------------------------------------------------------
# Keycloak — login dos usuários (OAuth2/OIDC)
# -----------------------------------------------------------------------------
# Client configurado no realm para o front-services
KEYCLOAK_CLIENT_ID=front-services
KEYCLOAK_CLIENT_SECRET=SEGREDO_DO_CLIENT_NO_KEYCLOAK

# Issuer do realm (sem barra final)
# Formato: https://<host>/realms/<realm>
KEYCLOAK_ISSUER=https://auth.dev2b.tec.br/realms/dev2b

# -----------------------------------------------------------------------------
# Keycloak — Admin API (usado para criar/deletar usuários via API route)
#
# Reutiliza o mesmo client do login. Para funcionar, o client precisa ter:
#   - "Service accounts roles" habilitado (Clients → dev2b-app → Settings)
#   - Roles de realm-management atribuídas na aba "Service account roles":
#       manage-users  create-user  view-users  query-users
# Não são necessárias variáveis extras — usa KEYCLOAK_CLIENT_ID e
# KEYCLOAK_CLIENT_SECRET que já estão definidos acima.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Backend (Spring Boot) — acesso server-side (Next.js API routes)
# URL interna da rede Docker (sem barra final)
# -----------------------------------------------------------------------------
API_URL=http://app-agenda:8011

# -----------------------------------------------------------------------------
# Backend — acesso client-side (browser)
# URL pública da API (sem barra final)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://api.dev2b.tec.br

# -----------------------------------------------------------------------------
# WhatsApp Integration (app-integration-watts)
# URL pública da API de WhatsApp (sem barra final)
# Local: http://localhost:8012
# -----------------------------------------------------------------------------
NEXT_PUBLIC_WHATS_API_URL=https://whats-api.dev2b.tec.br
